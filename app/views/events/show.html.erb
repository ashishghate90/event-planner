<div class="container mt-5">
  <div class="card shadow p-4">
    <h2 class="mb-3"><%= @event.title %></h2>
    <p class="text-muted"><%= @event.start_time.strftime("%B %d, %Y %I:%M %p") %> to <%= @event.end_time.strftime("%I:%M %p") %></p>
    <p><strong>Location:</strong> <%= @event.location %></p>
    <p><%= @event.description %></p>

    <hr>

    <div class="d-flex justify-content-between align-items-center">
      <div>
        <% if current_user && @event.event_joiners.exists?(user: current_user) %>
          <%= button_to "Leave Event", event_leave_path(@event), method: :delete, data: { turbo_frame: dom_id(@event) }, class: "btn btn-outline-danger" %>
        <% else %>
          <%= button_to "Join Event", event_join_path(@event), method: :post, data: { turbo_frame: dom_id(@event) }, class: "btn btn-success" %>
        <% end %>
      </div>
      <small class="text-muted">Hosted by <%= @event.user.email %></small>
    </div>
  </div>
</div>
